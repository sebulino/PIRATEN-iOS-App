// MeinePIRATEN — sample secrets config
// Copy this file to Config/Secrets.xcconfig and fill in real values.
// Config/Secrets.xcconfig is gitignored and must never be committed.

// PiratenSSO (Keycloak)
SSO_CLIENT_ID = your-sso-client-id
SSO_REDIRECT_URI = your.app.scheme://auth/callback
KEYCLOAK_BASE_URL = https://sso.piratenpartei.de/realms/Piratenlogin

// Discourse
DISCOURSE_BASE_URL = https://diskussion.piratenpartei.de
DISCOURSE_CLIENT_ID = your-discourse-client-id
DISCOURSE_AUTH_REDIRECT_SCHEME = your-redirect-scheme
DISCOURSE_AUTH_REDIRECT_HOST = your-redirect-host
DISCOURSE_APP_NAME = MeinePIRATEN

// PIRATEN-Kanon (GitHub)
// Note: repo will move to the piratenpartei org in a future release.
// Until then, use the current owner.
KNOWLEDGE_REPO_OWNER = sebulino
KNOWLEDGE_REPO_NAME = PIRATEN-Kanon
KNOWLEDGE_REPO_BRANCH = main

// meine-piraten.de
MEINE_PIRATEN_BASE_URL = https://meine-piraten.de

// Agitatorrr (events / calendar)
AGITATORRR_BASE_URL = https://agitatorrr.de
